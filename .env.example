EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Clerk setup (required before running app):
#   1. Create project at https://dashboard.clerk.com
#   2. Copy Publishable Key -> EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY (or app.json extra.clerkPublishableKey)
#   3. Copy Secret Key -> backend/.env CLERK_SECRET_KEY
#   4. Copy JWKS URL -> backend/.env CLERK_JWKS_URL
#      Format: https://<your-clerk-frontend-api>/.well-known/jwks.json
