# Backend env (copy ke .env, jangan commit nilai sebenarnya)

ENVIRONMENT=local
LOG_LEVEL=INFO

# Database (Supabase connection string atau local docker-compose)
DATABASE_URL=postgresql+asyncpg://lifebook:lifebook@postgres:5432/lifebook
SYNC_DATABASE_URL=postgresql://lifebook:lifebook@postgres:5432/lifebook

# Redis (Celery broker + cache)
REDIS_URL=redis://redis:6379/0

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL_QUESTION=gpt-4o
OPENAI_MODEL_NARRATIVE=gpt-4o
OPENAI_MODEL_EMBEDDING=text-embedding-3-small
OPENAI_MODEL_WHISPER=whisper-1
OPENAI_MODEL_IMAGE=gpt-image-2
OPENAI_IMAGE_SIZE=1024x1024
BOOK_GENERATION_AI_ENABLED=true
BOOK_GENERATION_OPENAI_TIMEOUT_SECONDS=20
BOOK_GENERATION_OPENAI_MAX_RETRIES=0

# Replicate (Flux 1.1 pro — Phase 3)
REPLICATE_API_TOKEN=
REPLICATE_MODEL_FLUX=black-forest-labs/flux-1.1-pro

# Clerk Auth
# Secret key dari https://dashboard.clerk.com -> API Keys
CLERK_SECRET_KEY=sk_test_...
# JWKS URL: https://<clerk-frontend-api>/.well-known/jwks.json
CLERK_JWKS_URL=https://YOUR_CLERK_DOMAIN.clerk.accounts.dev/.well-known/jwks.json

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=lifebook-dev
R2_ENDPOINT=https://CHANGE_ME.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://media-dev.lifebook.dev

# Lulu Direct (print vendor sandbox — Phase 4)
LULU_CLIENT_KEY=
LULU_CLIENT_SECRET=
LULU_API_BASE=https://api.sandbox.lulu.com

# RevenueCat webhook secret — Phase 3
REVENUECAT_WEBHOOK_SECRET=
